@model CSI402.ViewModels.ProjectUserViewModel

@{
    ViewData["Title"] = "Edit User";
    Layout = "_ProjectLayout";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-4">แก้ไขข้อมูลผู้ใช้</h2>

                <form method="post">
                    <div class="mb-3">
                        <label for="id" class="form-label">รหัสผู้ใช้</label>
                        <input type="text" class="form-control" id="id" readonly asp-for="Id">
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="name" class="form-label">ชื่อ</label>
                            <input type="text" class="form-control" id="name" placeholder="ชื่อของคุณ" required asp-for="Name">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="lastname" class="form-label">นามสกุล</label>
                            <input type="text" class="form-control" id="lastname" placeholder="นามสกุลของคุณ" required asp-for="Lastname">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label">อีเมล</label>
                        <input type="email" class="form-control" id="email" placeholder="example@gmail.com" required asp-for="Email">
                    </div>

                    <div class="mb-3">
                        <label for="phonenumber" class="form-label">เบอร์โทรศัพท์</label>
                        <input type="tel" class="form-control" id="phonenumber" placeholder="06x-xxxx-xxxx" required asp-for="PhoneNumber">
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">รหัสผ่าน</label>
                        <input type="password" class="form-control" id="password" placeholder="ใช้อย่างน้อย 8 ตัวอักษร" required minlength="8" asp-for="Password">
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-controller="Project" asp-action="UserList" class="btn btn-secondary me-md-2">ยกเลิก</a>
                        <button type="submit" class="btn btn-primary">บันทึกการแก้ไข</button>
                    </div>
                </form>

                <div class="border-top pt-3 text-center">
                    <p><a asp-controller="Project" asp-action="UserList" class="text-decoration-none">กลับรายชื่อผู้ใช้</a></p>
                </div>
            </div>
        </div>
    </div>
</div>