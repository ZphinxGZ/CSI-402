@* @using CSI402.ViewModels
@model List<ProjectUserViewModel> *@
@model List<CSI402.ViewModels.ProjectUserViewModel>

@{
    ViewData["Title"] = "User List";
    Layout = "_ProjectLayout";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">User List</h4>
        <a asp-controller="Project" asp-action="AddUserList" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add User
        </a>
    </div>
    <table class="table table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Lastname</th>
                <th>Email</th>
                <th>Phone</th>
                @* <th>Password</th> *@
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Name</td>
                    <td>@user.Lastname</td>
                    <td>@user.Email</td>
                    <td>@user.PhoneNumber</td>
                    @* <td>@user.Password</td> *@
                    <td>
                        <a asp-route-UID="@user.Id" asp-action="EditUser" asp-controller="Project" class="btn btn-warning btn-sm">Edit</a>
                        <a onclick="return confirm('คุณต้องการลบ @user.Name @user.Lastname หรือไม่')" asp-route-UID="@user.Id" asp-action="DeleteUser" asp-controller="Project" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                    
                </tr>
            }
        </tbody>
    </table>
</div>